# Optional — real AI providers (free tiers)
# Groq API key for LLM storyboard planning (get one at https://console.groq.com/keys)
# Can also be entered in the app's UI (stored in localStorage). Never commit a real key.
VITE_GROQ_API_KEY=

# Frame renderer: "pollinations" (real FLUX images, free, no key) or "procedural" (local SVG)
VITE_IMAGE_PROVIDER=pollinations
